{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "CommonJS",
    "target": "ES6",
    "removeComments": true,
    "strict": true,
    "sourceMap": false,
    "declaration": true,
    "noEmit": true,
  },
  "include": ["src/**/*", "public/example"],
  "exclude": ["node_modules", "**/__test__/*"],
}
