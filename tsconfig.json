{
  "compilerOptions": {
    "rootDir": "./packages",
    "outDir": "./dist",
    "module": "NodeNext",
    "target": "ES2024",
    "moduleResolution": "nodenext",
    "removeComments": true,
    "strict": true,
    "sourceMap": false,
    "declaration": true,
  },
  "include": ["packages/**/*", "public/example"],
  "exclude": ["node_modules", "packages/tests"],
}
